{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/builder.js": {
      "maxDuration": 120
    },
    "api/ai.js": {
      "maxDuration": 120
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/|assets/|images/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(favicon-16.png|favicon-32.png|icon-192.png|icon-512.png|apple-touch-icon.png|logo.png)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800, stale-while-revalidate=86400"
        }
      ]
    }
  ],
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/plan",
      "destination": "/trip-planner",
      "permanent": true
    },
    {
      "source": "/gallery",
      "destination": "/trip-ideas",
      "permanent": true
    },
    {
      "source": "/gallery/:slug",
      "destination": "/trip-ideas/:slug",
      "permanent": true
    }
  ]
}
