6ad82f?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHwlMjdzLUhlcnRvZ2VuYm9zY2glMjBTaW50LUphbnNrYXRoZWRyYWFsfGVufDF8MHx8fDE3ODM1MDM1NTF8MA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080"},{"id":"limburg","name":"Limburg","nameIt":"Limburg","capital":"Maastricht","lat":50.85,"lng":5.7,"emoji":"⛰️","colour":"ff2196f3","boundingBox":{"north":51.35,"south":50.45,"east":6.3,"west":5.5},"placeCount":6,"restaurantCount":14,"bestTimeToVisit":"Best visited from May to September for hiking, wine tasting, and outdoor activities.","heroImage":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1631107452534-b8f9868a8b20?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxNYWFzdHJpY2h0JTIwTWV1c2UlMjBSaXZlciUyMG1lZGlldmFsJTIwY2l0eXxlbnwxfDB8fHwxNzgzNTAzNjAxfDA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Giu Vicente"},"cardImage":"https://images.unsplash.com/photo-1631107452534-b8f9868a8b20?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxNYWFzdHJpY2h0JTIwTWV1c2UlMjBSaXZlciUyMG1lZGlldmFsJTIwY2l0eXxlbnwxfDB8fHwxNzgzNTAzNjAxfDA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080"}],"top10":[{"rank":1,"name":"Amsterdam","placeId":"amsterdam","regionId":"north_holland","regionName":"North Holland","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1534351590666-13e3e96b5017?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxBbXN0ZXJkYW0lMjBjYW5hbCUyMGhvdXNlc3xlbnwxfDB8fHwxNzgzNTAwNDE1fDA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Adrien Olichon"},"description":"The capital of the Netherlands and Noord-Holland's primary city, famous for its intricate canal system, world-class museums, and vibrant cultural scene. It is an essential destination for its Art Nouveau architecture, Anne Frank House, Van Gogh Museum, and bicycling culture."},{"rank":2,"name":"Rotterdam","placeId":"rotterdam","regionId":"south_holland","regionName":"South Holland","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1566525015882-701472b418fd?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxSb3R0ZXJkYW0lMjBDdWJlJTIwSG91c2VzfGVufDF8MHx8fDE3ODM1MDA0NTd8MA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Richard Ciraulo"},"description":"A major port city and architectural marvel rebuilt after World War II with striking modern design including the famous Cube Houses and Erasmus Bridge. It's a vibrant cultural hub with excellent museums, contemporary art scene, and innovative urban spaces that make it essential to understanding modern Netherlands."},{"rank":3,"name":"The Hague","placeId":"the_hague","regionId":"south_holland","regionName":"South Holland","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1577968681068-2d3e2521f7af?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxUaGUlMjBIYWd1ZSUyMFBlYWNlJTIwUGFsYWNlfGVufDF8MHx8fDE3ODM1MDA0NTl8MA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Joshua Kettle"},"description":"The Netherlands' administrative capital and seat of government, home to the International Court of Justice, Peace Palace, and numerous royal palaces. Its elegant squares, museums, and Scheveningen Beach make it one of the country's most important cultural and political centers."},{"rank":4,"name":"Canal Belt of Amsterdam","placeId":"canal_belt","regionId":"north_holland","regionName":"North Holland","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1534351590666-13e3e96b5017?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxDYW5hbCUyMEJlbHQlMjBvZiUyMEFtc3RlcmRhbSUyME5ldGhlcmxhbmRzfGVufDF8MHx8fDE3ODQwMjY5MDN8MA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Adrien Olichon"},"description":"A UNESCO World Heritage site comprising the famous concentric canal rings in Amsterdam's historic center, featuring 17th-century merchants' houses and bridges. It is one of the world's most iconic urban landscapes and a top attraction for photographers and sightseers."},{"rank":5,"name":"Kinderdijk","placeId":"kinderdijk","regionId":"south_holland","regionName":"South Holland","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1595698251407-8e7e3030a715?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxLaW5kZXJkaWprJTIwd2luZG1pbGxzJTIwVU5FU0NPfGVufDF8MHx8fDE3ODM1MDA0NjZ8MA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Thomas Bormans"},"description":"A UNESCO World Heritage site featuring 19 remarkably preserved 18th-century windmills arranged in a scenic landscape, representing the ingenuity of Dutch water management. It's an iconic symbol of Dutch engineering and one of the most photographed windmill collections in the world."},{"rank":6,"name":"Marken","placeId":"marken","regionId":"north_holland","regionName":"North Holland","image":null,"description":"A charming island village accessible by ferry or causeway, famous for its distinctive green and red wooden houses and strong maritime heritage. The island offers a peaceful escape with beautiful cycling routes, local museums, and traditional fishing culture."},{"rank":7,"name":"Volendam","placeId":"volendam","regionId":"north_holland","regionName":"North Holland","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1759711897058-5655d198cc44?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxWb2xlbmRhbSUyMHRyYWRpdGlvbmFsJTIwaG91c2VzfGVufDF8MHx8fDE3ODM1MDA0MTh8MA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"mana5280"},"description":"A picturesque fishing village on the Markermeer known for its traditional wooden houses, narrow waterfront streets, and authentic Dutch charm. It is a popular day trip from Amsterdam with excellent seafood restaurants and traditional costume photography opportunities."},{"rank":8,"name":"Keukenhof Gardens","placeId":"keukenhof","regionId":"south_holland","regionName":"South Holland","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1651422933132-d3e8822d8b40?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxLZXVrZW5ob2YlMjBHYXJkZW5zJTIwTmV0aGVybGFuZHN8ZW58MXwwfHx8MTc4NDAyNjk1OXww&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Farah Almazouni"},"description":"One of the world's largest flower gardens located near Lisse, Keukenhof showcases millions of tulips, dahlias, and other spring flowers in stunning displays. It attracts hundreds of thousands of visitors during its spring season to celebrate Dutch horticultural excellence."},{"rank":9,"name":"Delft","placeId":"delft","regionId":"south_holland","regionName":"South Holland","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1612646444409-ded6a340899f?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxEZWxmdCUyMGJsdWUlMjBwb3R0ZXJ5fGVufDF8MHx8fDE3ODM1MDA0NjF8MA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Rafik Wahba"},"description":"A picturesque historic town famous for its blue and white pottery, charming canals, and the tomb of William of Orange in the Old Church. Its perfectly preserved medieval streets and Vermeer connections make it one of the Netherlands' most photographed and visited towns."},{"rank":10,"name":"Zaanse Schans","placeId":"zaanse_schans","regionId":"north_holland","regionName":"North Holland","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1558000143-a78f8299c40b?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxaYWFuc2UlMjBTY2hhbnMlMjBOZXRoZXJsYW5kc3xlbnwxfDB8fHwxNzg0MDI2OTA1fDA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Michal Soukup"},"description":"An open-air museum featuring reconstructed 18th and 19th-century windmills, homes, and workshops showcasing traditional Dutch crafts and rural life. It offers visitors an immersive experience of historic Dutch heritage within easy reach of Amsterdam."}]}