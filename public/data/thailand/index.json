7.3},"placeCount":8,"restaurantCount":15,"bestTimeToVisit":"November to April provides calm seas and sunny weather ideal for beach and island activities.","heroImage":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1591357629414-80dce3b78d2b?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxLcmFiaSUyMGxpbWVzdG9uZSUyMGNsaWZmc3xlbnwxfDB8fHwxNzgzNTQ1OTIwfDA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Ivan Nedelchev"},"cardImage":"https://images.unsplash.com/photo-1591357629414-80dce3b78d2b?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxLcmFiaSUyMGxpbWVzdG9uZSUyMGNsaWZmc3xlbnwxfDB8fHwxNzgzNTQ1OTIwfDA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080"}],"top10":[{"rank":1,"name":"Bangkok","placeId":"bangkok","regionId":"central_plains","regionName":"Central Plains","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1736128023093-9a2d76b20cf2?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxCYW5na29rJTIwR3JhbmQlMjBQYWxhY2UlMjBnb2xkZW4lMjBzcGlyZXN8ZW58MXwwfHx8MTc4MzU0MDEyOXww&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Vasant Jain"},"description":"Thailand's bustling capital and largest city, home to ornate temples, palaces, and world-class museums alongside vibrant street food and nightlife. A cultural and commercial hub that anchors any Central Plains itinerary with unmissable sites like the Grand Palace and Wat Phra Kaew."},{"rank":2,"name":"Phuket","placeId":"phucket","regionId":"western","regionName":"Western Thailand","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1693494813069-b83e8eaca59a?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxQaHVrZXQlMjBQYXRvbmclMjBCZWFjaCUyMFRoYWlsYW5kfGVufDF8MHx8fDE3ODM1NDIxNzd8MA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Maksim Zhashkevych"},"description":"Thailand's largest island and premier beach destination, Phuket offers diverse attractions from bustling Patong Beach to tranquil southern shores and vibrant nightlife. It serves as the gateway to the Andaman Sea and is essential for its resorts, restaurants, water sports, and cultural sites like Big Buddha and Old Phuket Town."},{"rank":3,"name":"Krabi","placeId":"krabi","regionId":"western","regionName":"Western Thailand","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1764753318137-4593b8125a51?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxSYWlsYXklMjBCZWFjaCUyMEtyYWJpJTIwbGltZXN0b25lJTIwY2xpZmZzfGVufDF8MHx8fDE3ODM1NDIxNzl8MA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"SERGEI BEZZUBOV"},"description":"A coastal province famous for dramatic limestone cliffs, turquoise waters, and some of Thailand's most scenic beaches including Railay and Ao Nang. Krabi is the adventure capital of the south, offering rock climbing, snorkeling, island hopping, and laid-back beach town atmosphere."},{"rank":4,"name":"Chiang Mai","placeId":"chiang_mai","regionId":"northern","regionName":"Northern Thailand","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1599576838688-8a6c11263108?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxDaGlhbmclMjBNYWklMjBvbGQlMjBjaXR5JTIwdGVtcGxlc3xlbnwxfDB8fHwxNzgzNTQyMDQxfDA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Peter Borter"},"description":"Thailand's largest northern city and cultural heartland, famous for hundreds of temples, night markets, and traditional Lanna architecture. It's the primary gateway to northern Thailand and offers everything from ancient ruins to elephant sanctuaries and cooking classes."},{"rank":5,"name":"Pattaya","placeId":"pattaya","regionId":"eastern","regionName":"Eastern Thailand","image":null,"description":"Thailand's most famous beach resort city, known for its long sandy beaches, vibrant nightlife, and water sports. A major hub offering everything from relaxation to adventure, with excellent infrastructure and accessibility from Bangkok."},{"rank":6,"name":"Koh Samui","placeId":"koh_samui","regionId":"southern_peninsula","regionName":"Southern Peninsula","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1556463207-5f043fc03306?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxLb2glMjBTYW11aSUyMEJpZyUyMEJ1ZGRoYXxlbnwxfDB8fHwxNzgzNTQ1ODg5fDA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Kit Suman"},"description":"Thailand's second-largest island, Koh Samui is known for luxury resorts, excellent beaches, and the famous Big Buddha statue. It offers a perfect blend of natural beauty, nightlife, and upscale amenities."},{"rank":7,"name":"Ayutthaya","placeId":"ayutthaya","regionId":"central_plains","regionName":"Central Plains","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1626197798581-d35c41d9fa27?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxBeXV0dGhheWElMjB0ZW1wbGUlMjBydWlucyUyMGFuY2llbnR8ZW58MXwwfHx8MTc4MzU0MDEzMXww&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Albert Potjes"},"description":"A UNESCO World Heritage Site and former Thai capital with hundreds of temple ruins scattered across the riverside landscape, offering glimpses into 400 years of Southeast Asian history. The atmospheric remains of ancient structures make it one of Thailand's most evocative historical destinations."},{"rank":8,"name":"Koh Phi Phi","placeId":"koh_phi_phi","regionId":"andaman_coast","regionName":"Andaman Coast","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1552465011-b4e21bf6e79a?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxLb2glMjBQaGklMjBQaGklMjBUaGFpbGFuZHxlbnwxfDB8fHwxNzg0MDMwODc0fDA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Sumit Chinchane"},"description":"A picturesque island group famous for stunning beaches, crystal-clear waters, and vibrant coral reefs. Made iconic by the film 'The Beach,' it has become essential for visitors seeking tropical island paradise and snorkeling opportunities."},{"rank":9,"name":"Sukhothai","placeId":"sukhothai","regionId":"northern","regionName":"Northern Thailand","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1707789030176-0e51968b7768?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxTdWtob3RoYWklMjBoaXN0b3JpY2FsJTIwcGFyayUyMHRlbXBsZXN8ZW58MXwwfHx8MTc4MzU0MDEzNXww&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"CJ"},"description":"A UNESCO World Heritage historical park south of northern Thailand featuring ancient temple ruins from the 13th-15th centuries, representing the first major Thai kingdom. The open-air park with hundreds of temples set in serene gardens is one of Thailand's most important archaeological sites."},{"rank":10,"name":"Koh Tao","placeId":"koh_tao","regionId":"southern_peninsula","regionName":"Southern Peninsula","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1637308107080-82cf40953742?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxLb2glMjBUYW8lMjBkaXZpbmclMjBjb3JhbCUyMHJlZWZ8ZW58MXwwfHx8MTc4MzU0NTg5MXww&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Oleksandr Sushko"},"description":"A small island renowned as one of the world's best and most affordable places to learn scuba diving. Koh Tao offers vibrant coral reefs, marine life, and a laid-back atmosphere popular with backpackers and divers."}]}