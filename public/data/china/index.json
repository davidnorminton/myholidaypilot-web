oImage":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1588423886412-914102b72f96?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxHdWlsaW4lMjBrYXJzdCUyMG1vdW50YWlucyUyMExpJTIwUml2ZXJ8ZW58MXwwfHx8MTc4Mzk0MDg1MXww&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Camillo Corsetti Antonini"},"cardImage":"https://images.unsplash.com/photo-1588423886412-914102b72f96?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxHdWlsaW4lMjBrYXJzdCUyMG1vdW50YWlucyUyMExpJTIwUml2ZXJ8ZW58MXwwfHx8MTc4Mzk0MDg1MXww&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080"},{"id":"guizhou","name":"Guizhou","nameIt":"贵州","capital":"Guiyang","lat":26.6,"lng":106.7,"emoji":"💧","colour":"ffff9800","boundingBox":{"north":29.1,"south":23.8,"east":109.8,"west":103.7},"placeCount":13,"restaurantCount":14,"bestTimeToVisit":"Visit in spring (March-May) or autumn (September-November) for scenic beauty and mild weather.","heroImage":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1570495074897-c5960b05c60a?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxaaGVueXVhbiUyMGFuY2llbnQlMjB0b3duJTIwcml2ZXJzaWRlJTIwR3VpemhvdXxlbnwxfDB8fHwxNzgzOTQ0MTI5fDA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"花茶 利酒"},"cardImage":"https://images.unsplash.com/photo-1570495074897-c5960b05c60a?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxaaGVueXVhbiUyMGFuY2llbnQlMjB0b3duJTIwcml2ZXJzaWRlJTIwR3VpemhvdXxlbnwxfDB8fHwxNzgzOTQ0MTI5fDA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080"}],"top10":[{"rank":1,"name":"Beijing","placeId":"beijing","regionId":"beijing_tianjin_hebei","regionName":"Beijing, Tianjin & Hebei","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1708660575990-101db3b00294?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxCZWlqaW5nJTIwc2t5bGluZSUyMG5pZ2h0fGVufDF8MHx8fDE3ODM5MzA0NjZ8MA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"chen zy"},"description":"China's capital and political heart, blending ancient imperial heritage with cutting-edge modernity across 16 districts. Essential for experiencing traditional culture, world-class museums, hutong neighborhoods, and contemporary Asian dynamism."},{"rank":2,"name":"Shanghai","placeId":"shanghai","regionId":"yangtze_river","regionName":"Yangtze River Region","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1474181487882-5abf3f0ba6c2?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxTaGFuZ2hhaSUyMEJ1bmQlMjBza3lsaW5lJTIwbmlnaHR8ZW58MXwwfHx8MTc4MzkzMzU2Nnww&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Li Yang"},"description":"China's largest city and a global financial hub where ultramodern skyscrapers meet colonial architecture along the Huangpu River. The Bund, Yu Garden, and Oriental Pearl Tower showcase the city's blend of tradition and cutting-edge modernity."},{"rank":3,"name":"Great Wall of China","placeId":"great_wall","regionId":"beijing_tianjin_hebei","regionName":"Beijing, Tianjin & Hebei","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1500297726361-1715d90aec00?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxHcmVhdCUyMFdhbGwlMjBCZWlqaW5nJTIwQmFkYWxpbmd8ZW58MXwwfHx8MTc4MzkzMDQ2Mnww&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Melissa"},"description":"The world's longest fortification spanning over 13,000 miles, with the most accessible and well-preserved sections near Beijing at Badaling and Mutianyu. A symbol of China and one of humanity's most impressive architectural feats."},{"rank":4,"name":"Guilin","placeId":"guilin","regionId":"guangxi","regionName":"Guangxi","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1588423886412-914102b72f96?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxHdWlsaW4lMjBrYXJzdCUyMG1vdW50YWlucyUyMExpJTIwUml2ZXJ8ZW58MXwwfHx8MTc4Mzk0MDg1MXww&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Camillo Corsetti Antonini"},"description":"Guilin is renowned for its dramatic karst mountains rising from the Li River, offering some of China's most iconic natural scenery. The city serves as the gateway to river cruises and hiking adventures through stunning limestone peaks dotted with caves and traditional villages."},{"rank":5,"name":"Xi'an","placeId":"xi_an","regionId":"yellow_river","regionName":"Yellow River Region","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1527922891260-918d42a4efc8?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxYaSUyN2FuJTIwVGVycmFjb3R0YSUyMEFybXklMjB3YXJyaW9yc3xlbnwxfDB8fHwxNzgzOTMzNTI0fDA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Aaron Greenwood"},"description":"China's ancient capital and one of the world's most historically important cities, Xi'an is home to the famous Terracotta Army and sits along the Wei River, a major Yellow River tributary. The city's ancient walls, museums, and Buddhist temples make it essential for understanding Chinese civilization."},{"rank":6,"name":"Hangzhou","placeId":"hangzhou","regionId":"east_coast","regionName":"East Coast","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1669532055370-b0c282cb115f?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxXZXN0JTIwTGFrZSUyMEhhbmd6aG91JTIwc3Vuc2V0fGVufDF8MHx8fDE3ODM5MzM1Mzd8MA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Frudrax Cheng"},"description":"Famous for its stunning West Lake with misty mountains and classical pavilions, Hangzhou is a spiritual and romantic destination that has inspired artists for centuries. The lake-side scenery, ancient temples, and excellent tea culture create an unforgettable experience."},{"rank":7,"name":"Forbidden City","placeId":"forbidden_city","regionId":"beijing_tianjin_hebei","regionName":"Beijing, Tianjin & Hebei","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1592620540259-75b9f6500187?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxGb3JiaWRkZW4lMjBDaXR5JTIwQmVpamluZyUyMGFlcmlhbHxlbnwxfDB8fHwxNzgzOTMwNDYwfDA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Snowscat"},"description":"The largest palace complex in the world and former home of Chinese emperors, spanning nearly 1,000 buildings across 72 hectares. A UNESCO World Heritage site essential for understanding imperial Chinese history and architecture."},{"rank":8,"name":"Zhangjiajie","placeId":"zhangjiajie","regionId":"south_central","regionName":"South Central","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1567266565446-d9c40ccf59a4?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxaaGFuZ2ppYWppZSUyME5hdGlvbmFsJTIwRm9yZXN0JTIwUGFyayUyMHBpbGxhcnN8ZW58MXwwfHx8MTc4MzkzMzU5MHww&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Robynne O"},"description":"Famous for its towering sandstone pillars that inspired Avatar's landscape, Zhangjiajie National Forest Park is one of China's most spectacular natural wonders. Visitors can hike through mist-shrouded mountains, cross glass bridges, and witness breathtaking panoramic views."},{"rank":9,"name":"Chengdu","placeId":"chengdu","regionId":"southwest","regionName":"Southwest","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1566487097168-e91a4f38bee2?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxDaGVuZ2R1JTIwZ2lhbnQlMjBwYW5kYXxlbnwxfDB8fHwxNzgzOTMzNzMzfDA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Yu Wang"},"description":"The capital of Sichuan Province, famous as the giant panda capital of the world and a center of Chinese culture and cuisine. Home to the Chengdu Research Base of Giant Panda Breeding and vibrant teahouses, street food, and ancient temples."},{"rank":10,"name":"Nanjing","placeId":"nanjing","regionId":"east_coast","regionName":"East Coast","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1748345743667-eaa134c699e3?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxOYW5qaW5nJTIwTWluZyUyMFhpYW9saW5nJTIwTWF1c29sZXVtfGVufDF8MHx8fDE3ODM5MzM1Mzl8MA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Han mo"},"description":"A historic capital with profound cultural significance, Nanjing offers imperial relics, the magnificent Ming Xiaoling Mausoleum, and the serene Confucius Temple along the Qinhuai River. The city combines ancient Chinese heritage with modern vibrancy and excellent museums."}]}