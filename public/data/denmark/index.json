lash.com/photo-1774631564031-8d57b11fc2e0?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxBYWxib3JnJTIwd2F0ZXJmcm9udCUyMGhhcmJvcnxlbnwxfDB8fHwxNzgzNzc2MzM2fDA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080"}],"top10":[{"rank":1,"name":"Copenhagen","placeId":"copenhagen_city","regionId":"copenhagen_region","regionName":"Copenhagen Region","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1693085777086-1da3abf20d75?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxOeWhhdm4lMjBDb3BlbmhhZ2VuJTIwd2F0ZXJmcm9udHxlbnwxfDB8fHwxNzgzNzY1ODU3fDA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Sabrina Mazzeo"},"description":"Denmark's vibrant capital and largest city, featuring the iconic Nyhavn waterfront, Tivoli Gardens amusement park, and Christiansborg Palace. It's the cultural and historical heart of Denmark with world-class museums, restaurants, and a bicycle-friendly atmosphere that defines modern Scandinavian living."},{"rank":2,"name":"Billund","placeId":"billund","regionId":"south_denmark","regionName":"South Denmark","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1764620599401-600ddff2a9e7?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxMRUdPTEFORCUyMEJpbGx1bmQlMjB0aGVtZSUyMHBhcmt8ZW58MXwwfHx8MTc4Mzc2ODUzOHww&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Anakin"},"description":"Home to the world-famous LEGOLAND theme park, one of Europe's most visited attractions with rides, shows, and millions of LEGO bricks. Essential for families and LEGO enthusiasts, offering a full day of interactive entertainment."},{"rank":3,"name":"Odense","placeId":"odense","regionId":"funen","regionName":"Funen","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1755107428240-f54f98976083?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxPZGVuc2UlMjBjYW5hbCUyMERlbm1hcmt8ZW58MXwwfHx8MTc4Mzc2ODQ2MHww&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"balint henter"},"description":"Denmark's third-largest city and the birthplace of Hans Christian Andersen, offering museums, historic architecture, and charming canals. The H.C. Andersen House and the vibrant city center make it essential for understanding Danish culture and fairy tale heritage."},{"rank":4,"name":"Aarhus","placeId":"aarhus","regionId":"central_jutland","regionName":"Central Jutland","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1570411957736-3f9d0640a75e?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxBUm9TJTIwQWFyaHVzJTIwcmFpbmJvdyUyMHBhbm9yYW1hfGVufDF8MHx8fDE3ODM3NzI0NTl8MA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Anders Krøgh Jørgensen"},"description":"Denmark's second-largest city and the cultural heart of Jutland, featuring the outstanding ARoS art museum, vibrant harbor front, and charming Old Town with half-timbered houses. It's a dynamic destination combining world-class museums, excellent restaurants, and a youthful energy that makes it essential for any visit to Central Jutland."},{"rank":5,"name":"Helsingør","placeId":"helsing_r","regionId":"capital_region","regionName":"Capital Region","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1748814670185-ae3f3b8fee7d?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxLcm9uYm9yZyUyMENhc3RsZSUyMEhlbHNpbmclQzMlQjhyfGVufDF8MHx8fDE3ODM3NjU4MzN8MA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Tannis Sullivan"},"description":"A picturesque coastal town famous for Kronborg Castle, the fortress that inspired Shakespeare's Hamlet, situated dramatically on the Øresund Strait. The charming medieval old town and proximity to Sweden across the narrow strait make it an essential destination."},{"rank":6,"name":"Roskilde","placeId":"roskilde","regionId":"copenhagen_region","regionName":"Copenhagen Region","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1653854309135-c79da0ed007a?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxSb3NraWxkZSUyMENhdGhlZHJhbCUyMERlbm1hcmt8ZW58MXwwfHx8MTc4Mzc2NTgzMXww&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Daniel Marshall"},"description":"An ancient Viking settlement and former royal capital home to the spectacular Roskilde Cathedral, a UNESCO World Heritage site housing the tombs of Danish monarchs. The town also features the impressive Viking Ship Museum and hosts the famous Roskilde Festival, making it essential for history and culture enthusiasts."},{"rank":7,"name":"Skagen","placeId":"skagen","regionId":"south_denmark","regionName":"South Denmark","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1544115341-95f8fc9d9df6?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxTa2FnZW4lMjBHcmVuZW4lMjB0d28lMjBzZWFzJTIwbWVldGluZ3xlbnwxfDB8fHwxNzgzNzY4NTUxfDA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Ihor Malytskyi"},"description":"Denmark's northernmost town where the North Sea and Baltic Sea meet, famous for the dramatic Grenen point, shifting sand dunes, and its golden-hour light celebrated by painters. Iconic for its rugged coastal beauty and the unique natural phenomenon of two seas colliding."},{"rank":8,"name":"Ribe","placeId":"ribe","regionId":"south_denmark","regionName":"South Denmark","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1624190715464-7515991cb37f?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxSaWJlJTIwbWVkaWV2YWwlMjB0b3duJTIwRGVubWFya3xlbnwxfDB8fHwxNzgzNzY4NTQwfDA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Machrife"},"description":"Denmark's oldest town, featuring a remarkably preserved medieval town center with half-timbered houses, cobbled streets, and the impressive Ribe Cathedral from the 12th century. The authentic atmosphere and historical character make it one of Denmark's most charming destinations."},{"rank":9,"name":"Bornholm","placeId":"bornholm","regionId":"bornholm","regionName":"Bornholm","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1560552451-97b5ee52847d?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxCb3JuaG9sbSUyMERlbm1hcmt8ZW58MXwwfHx8MTc4NDAzMTUyNHww&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Febiyan"},"description":"A picturesque island in the Baltic Sea known for its dramatic granite cliffs, sandy beaches, and distinctive round churches. Visitors are drawn to its scenic coastal landscapes, outdoor recreation opportunities, and charming villages with a distinct Nordic character."},{"rank":10,"name":"Drågør","placeId":"dragor","regionId":"copenhagen_region","regionName":"Copenhagen Region","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1551651767-d5ffbdd04b83?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxEciVDMyVBNWclQzMlQjhyJTIwaGFyYm9yJTIwRGVubWFya3xlbnwxfDB8fHwxNzgzNzY1ODcxfDA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Ava Coploff"},"description":"A charming maritime village on the island of Amager with cobblestone streets, colorful historic buildings, and a picturesque harbor full of sailboats. Once an important herring fishing port, it now offers a peaceful retreat with excellent restaurants and a glimpse into traditional Danish coastal life just outside Copenhagen."}]}