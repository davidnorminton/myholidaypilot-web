ng oases.","heroImage":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1727359714097-7c8f5e96023f?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxTaXdhJTIwT2FzaXMlMjBFZ3lwdCUyMHBhbG0lMjB0cmVlc3xlbnwxfDB8fHwxNzgzODQyMTQ3fDA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"S L"},"cardImage":"https://images.unsplash.com/photo-1727359714097-7c8f5e96023f?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxTaXdhJTIwT2FzaXMlMjBFZ3lwdCUyMHBhbG0lMjB0cmVlc3xlbnwxfDB8fHwxNzgzODQyMTQ3fDA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080"},{"id":"sinai_peninsula","name":"Sinai Peninsula","nameIt":"شبه جزيرة سيناء","capital":"El Arish","lat":31.1256,"lng":33.1993,"emoji":"⛰️","colour":"ffff5722","boundingBox":{"north":31.7,"south":27.7,"east":34.9,"west":32.4},"placeCount":7,"restaurantCount":14,"bestTimeToVisit":"October to April offers pleasant temperatures for hiking Mount Sinai and exploring Bedouin culture.","heroImage":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1708694423464-0f5b19fb2444?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxTaGFybSUyMEVsLVNoZWlraCUyMGJlYWNoJTIwcmVzb3J0fGVufDF8MHx8fDE3ODM4NDIyMDV8MA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Anastasiia Popova"},"cardImage":"https://images.unsplash.com/photo-1708694423464-0f5b19fb2444?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxTaGFybSUyMEVsLVNoZWlraCUyMGJlYWNoJTIwcmVzb3J0fGVufDF8MHx8fDE3ODM4NDIyMDV8MA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080"}],"top10":[{"rank":1,"name":"Giza Plateau","placeId":"giza_pyramids","regionId":"cairo_giza","regionName":"Cairo & Giza","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1635446997009-a1fd4a92dbe6?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxHaXphJTIwUGxhdGVhdSUyMEVneXB0fGVufDF8MHx8fDE3ODQwMzE2NDF8MA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"SOURAV BHADRA"},"description":"Home to the Great Pyramids of Khufu, Khafre, and Menkaure, plus the Sphinx, representing the pinnacle of ancient Egyptian engineering and artistry. It is the most iconic archaeological site in Egypt and attracts millions of visitors annually seeking to witness these 4,500-year-old wonders."},{"rank":2,"name":"Cairo","placeId":"cairo_city","regionId":"cairo_giza","regionName":"Cairo & Giza","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1572252009286-268acec5ca0a?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxDYWlybyUyMEVneXB0JTIwY2l0eSUyMHNreWxpbmV8ZW58MXwwfHx8MTc4MzgwMTMwMnww&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Omar Elsharawy"},"description":"The sprawling capital of Egypt and Africa's largest city, straddling the Nile River with over 20 million inhabitants and blending ancient pharaonic heritage, Islamic medieval districts, colonial architecture, and modern neighborhoods. Cairo is the cultural and historical heart of Egypt, offering world-class museums, historic mosques, vibrant markets, and an intoxicating urban atmosphere."},{"rank":3,"name":"Luxor","placeId":"luxor_city","regionId":"luxor_thebes","regionName":"Luxor & Thebes","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1678308510980-e855e5f31dea?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxMdXhvciUyMGNpdHklMjBOaWxlJTIwRWd5cHR8ZW58MXwwfHx8MTc4MzgwNDA3MXww&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"2H Media"},"description":"The modern city of Luxor sits on the east bank of the Nile and serves as the primary hub for visiting ancient Thebes. It offers excellent hotels, restaurants, and access to the region's most spectacular monuments."},{"rank":4,"name":"Valley of the Kings","placeId":"valley_of_kings","regionId":"luxor_thebes","regionName":"Luxor & Thebes","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1693947241038-da20ccf789db?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxWYWxsZXklMjBvZiUyMHRoZSUyMEtpbmdzJTIwdG9tYnN8ZW58MXwwfHx8MTc4MzgwNDA1NHww&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Museum of New Zealand Te Papa Tongarewa"},"description":"This vast necropolis on the west bank contains 62 royal tombs carved into rock cliffs, including the famous tomb of Tutankhamun. It remains the most iconic archaeological site in Egypt and a must-see for understanding pharaonic burial practices."},{"rank":5,"name":"Aswan","placeId":"aswan","regionId":"upper_egypt","regionName":"Upper Egypt","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1567444224998-d6fa982910dc?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxBc3dhbiUyMGZlbHVjY2ElMjBib2F0cyUyMHN1bnNldHxlbnwxfDB8fHwxNzgzODA0MDQwfDA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Igor Rodrigues"},"description":"Egypt's southernmost major city, Aswan is known for its relaxed atmosphere, stunning Nile views, and proximity to Abu Simbel and the Aswan Dam. The city serves as a gateway to Nubia and offers felucca sailing, colorful markets, and beautiful desert landscapes."},{"rank":6,"name":"Abu Simbel","placeId":"abu_simbel","regionId":"aswan_nubia","regionName":"Aswan & Nubia","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1742262379112-eacb2813ca6d?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxBYnUlMjBTaW1iZWwlMjB0ZW1wbGVzJTIwbWFzc2l2ZSUyMHN0YXR1ZXN8ZW58MXwwfHx8MTc4MzgwNDExNHww&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Tang wei-chen"},"description":"Two colossal rock temples carved directly into a mountainside, dating to Ramesses II's reign, featuring four 67-meter-high statues of the pharaoh at the entrance. This UNESCO World Heritage site is one of Egypt's most iconic monuments and was dramatically relocated in the 1960s to save it from Lake Nasser's flooding."},{"rank":7,"name":"Hurghada","placeId":"hurghada","regionId":"red_sea","regionName":"Red Sea Riviera","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1755545414327-36524febb5b6?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxIdXJnaGFkYSUyMFJlZCUyMFNlYSUyMGJlYWNoJTIwcmVzb3J0fGVufDF8MHx8fDE3ODM4MDQwMDh8MA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Jayde Keroi"},"description":"Egypt's largest Red Sea resort city and gateway to the Riviera, offering world-class diving, snorkeling, and beach resorts. The Marina and downtown areas buzz with restaurants, shops, and watersports operators catering to international visitors."},{"rank":8,"name":"Sharm El-Sheikh","placeId":"sharm_el_sheikh","regionId":"sinai_peninsula","regionName":"Sinai Peninsula","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1708694423464-0f5b19fb2444?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxTaGFybSUyMEVsLVNoZWlraCUyMGJlYWNoJTIwcmVzb3J0fGVufDF8MHx8fDE3ODM4NDIyMDV8MA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Anastasiia Popova"},"description":"A world-class Red Sea resort city known for its pristine beaches, coral reefs, and luxury accommodations. It's the premier destination for diving, snorkeling, and water sports in the region with excellent infrastructure and nightlife."},{"rank":9,"name":"Karnak Temple","placeId":"karnak_temple","regionId":"luxor_thebes","regionName":"Luxor & Thebes","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1710886324980-997f7742f16c?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxLYXJuYWslMjBUZW1wbGUlMjBjb2x1bW5zJTIwRWd5cHR8ZW58MXwwfHx8MTc4MzgwNDA3Nnww&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Ahmed Elnokrashy"},"description":"This massive temple complex dedicated to Amun-Ra is the largest religious structure ever built, featuring towering pylons, colossal statues, and the hypostyle hall with 134 columns. Walking through Karnak is essential to comprehending the scale and ambition of ancient Egyptian architecture."},{"rank":10,"name":"Alexandria","placeId":"alexandria","regionId":"nile_delta","regionName":"Nile Delta","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1697546889969-27f7b5be8664?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxDaXRhZGVsJTIwb2YlMjBRYWl0YmF5JTIwQWxleGFuZHJpYXxlbnwxfDB8fHwxNzgzODAxMzU1fDA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"abdullah ali"},"description":"Egypt's second-largest city and ancient Mediterranean port founded by Alexander the Great, featuring the iconic Citadel of Qaitbay built on the site of the ancient Lighthouse of Alexandria. The city blends Greco-Roman history with Hellenistic culture, offering museums, beaches, and a cosmopolitan atmosphere unmatched elsewhere in Egypt."}]}