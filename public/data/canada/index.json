hts.","heroImage":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1766699622933-b71dfc16b1e7?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxHcmlzZSUyMEZpb3JkJTIwQXVqdWl0dHVxJTIwQXJjdGljJTIwc2V0dGxlbWVudHxlbnwxfDB8fHwxNzgzNzk2NjQ0fDA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Gunnar Ridderström"},"cardImage":"https://images.unsplash.com/photo-1766699622933-b71dfc16b1e7?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxHcmlzZSUyMEZpb3JkJTIwQXVqdWl0dHVxJTIwQXJjdGljJTIwc2V0dGxlbWVudHxlbnwxfDB8fHwxNzgzNzk2NjQ0fDA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080"}],"top10":[{"rank":1,"name":"Niagara Falls","placeId":"niagara_falls","regionId":"ontario","regionName":"Ontario","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1598402453861-4fbcbf6ced3b?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxOaWFnYXJhJTIwRmFsbHMlMjB3YXRlcmZhbGwlMjBjYXNjYWRlfGVufDF8MHx8fDE3ODM3OTA0NTF8MA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Rikin Katyal"},"description":"One of the world's most iconic waterfalls, straddling the Canada-US border with a powerful cascade of over 50 meters. It is the premier natural attraction in Ontario and offers boat tours, viewing platforms, and surrounding parks."},{"rank":2,"name":"Toronto","placeId":"toronto","regionId":"ontario","regionName":"Ontario","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1507992781348-310259076fe0?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxUb3JvbnRvJTIwQ04lMjBUb3dlciUyMHNreWxpbmV8ZW58MXwwfHx8MTc4Mzc5MDQ1M3ww&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Berkay Gumustekin"},"description":"Canada's largest city, known for the iconic CN Tower, diverse neighborhoods, world-class museums, and vibrant cultural scene. It serves as the economic and cultural heart of Ontario with excellent dining, shopping, and entertainment."},{"rank":3,"name":"Vancouver","placeId":"vancouver","regionId":"british_columbia","regionName":"British Columbia","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1655097777728-b9b56af9ff7e?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxWYW5jb3V2ZXIlMjBza3lsaW5lJTIwbW91bnRhaW5zJTIwb2NlYW58ZW58MXwwfHx8MTc4Mzc4NzU3OHww&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Sophie N"},"description":"Canada's third-largest city, dramatically situated between mountains and ocean, known for its cosmopolitan culture, culinary scene, and outdoor recreation. It's the gateway to exploring British Columbia and offers world-class museums, parks like Stanley Park, and views of the North Shore mountains."},{"rank":4,"name":"Banff National Park","placeId":"banff_national_park","regionId":"alberta","regionName":"Alberta","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/flagged/photo-1561805108-04d5124771dd?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxCYW5mZiUyMExha2UlMjBMb3Vpc2UlMjB0dXJxdW9pc2V8ZW58MXwwfHx8MTc4Mzc4NzYxM3ww&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Jelmer Borst"},"description":"Canada's oldest national park featuring dramatic Rocky Mountain peaks, turquoise glacial lakes, and abundant wildlife. It's essential for hiking, scenic drives, and experiencing pristine wilderness that defines the Canadian Rockies."},{"rank":5,"name":"Montreal","placeId":"montreal","regionId":"quebec","regionName":"Quebec","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1767290444122-5230a7fefef7?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxPbGQlMjBNb250cmVhbCUyMGNvYmJsZXN0b25lJTIwc3RyZWV0c3xlbnwxfDB8fHwxNzgzNzkwNDgyfDA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Sadia Afreen"},"description":"Canada's second-largest city and Quebec's cultural heart, featuring stunning architecture, world-class museums, and vibrant neighborhoods like the Plateau and Old Montreal. It's a bilingual metropolis with excellent food, nightlife, and artistic scenes that make it essential for any Quebec visit."},{"rank":6,"name":"Lake Louise","placeId":"lake_louise","regionId":"alberta","regionName":"Alberta","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1594741873407-c292ca075f8b?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxMYWtlJTIwTG91aXNlJTIwdHVycXVvaXNlJTIwZ2xhY2llcnxlbnwxfDB8fHwxNzgzNzg3NjE4fDA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Charlie Gallant"},"description":"One of the world's most photographed mountain lakes, surrounded by snow-capped peaks and accessible via scenic hiking trails. The stunning turquoise water reflects the surrounding mountains, making it a must-see natural wonder."},{"rank":7,"name":"Quebec City","placeId":"quebec_city","regionId":"quebec","regionName":"Quebec","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1540638185826-7b1a01210c2b?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxDaCVDMyVBMnRlYXUlMjBGcm9udGVuYWMlMjBRdWViZWMlMjBDaXR5fGVufDF8MHx8fDE3ODM3OTA0ODR8MA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Rich Martello"},"description":"North America's most European city with preserved 17th-century architecture, charming cobblestone streets, and the iconic Château Frontenac dominating the skyline. The walled Old City is a UNESCO World Heritage Site that captures French colonial history and offers excellent cuisine, galleries, and cultural experiences."},{"rank":8,"name":"Whistler Blackcomb","placeId":"whistler_blackcomb","regionId":"british_columbia","regionName":"British Columbia","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1713996184622-51fb2ce1e25f?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxXaGlzdGxlciUyMEJsYWNrY29tYiUyMHNraSUyMHJlc29ydHxlbnwxfDB8fHwxNzgzNzg3NTgyfDA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Kayvan Mazhar"},"description":"North America's largest ski resort, set in a stunning alpine landscape with world-renowned skiing and snowboarding in winter and mountain biking in summer. The pedestrian village at the base offers excellent restaurants, shops, and après-ski entertainment."},{"rank":9,"name":"Ottawa","placeId":"ottawa","regionId":"ontario","regionName":"Ontario","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1599457480385-83984b998663?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxQYXJsaWFtZW50JTIwSGlsbCUyME90dGF3YSUyMENhbmFkYXxlbnwxfDB8fHwxNzgzNzkwNDU1fDA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Chris DeSort"},"description":"Canada's capital city featuring Parliament Hill, the Canadian Museum of History, and the Rideau Canal—a UNESCO World Heritage Site. It combines government grandeur with cultural attractions and scenic riverside settings."},{"rank":10,"name":"Peggy's Cove","placeId":"peggy_cove","regionId":"nova_scotia","regionName":"Nova Scotia","image":{"index":0,"assetPath":"","isLocal":false,"url":"https://images.unsplash.com/photo-1586268948908-ec55eb75ea18?ixid=M3w5NTU4NjF8MHwxfHNlYXJjaHwxfHxQZWdneSUyN3MlMjBDb3ZlJTIwbGlnaHRob3VzZXxlbnwxfDB8fHwxNzgzNzk0MDcxfDA&ixlib=rb-4.1.0&crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1080","credit":"Tyler Maddigan"},"description":"An iconic postcard-perfect fishing village famous for its red-and-white striped lighthouse perched on massive granite rocks. The dramatic coastal scenery and working harbor make it one of Canada's most photographed lighthouses and a must-see on the South Shore."}]}