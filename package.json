{
  "name": "italy-travel-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n web,api -c cyan,green \"vite\" \"node --watch dev-server.mjs\"",
    "build": "node scripts/sync-images.mjs || true; node scripts/sync-details.mjs || true; node scripts/sync-viator.mjs || true; node scripts/bake-card-images.mjs && vite build && (node scripts/snapshot-screens.mjs || true) && node scripts/prerender.mjs",
    "preview": "vite preview",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node db/migrate.mjs",
    "db:seed": "node db/seed.mjs",
    "db:studio": "drizzle-kit studio",
    "db:reset": "rm -f local.db && npm run db:migrate && npm run db:seed",
    "dev:web": "vite",
    "dev:api": "node dev-server.mjs",
    "lint:hooks": "eslint --config eslint.hooks.config.mjs src --no-warn-ignored",
    "gen:countries": "node scripts/gen-countries.mjs",
    "prebuild": "node scripts/gen-countries.mjs && node scripts/build-map-index.mjs",
    "predev": "node scripts/gen-countries.mjs && node scripts/build-map-index.mjs",
    "test": "vitest run",
    "prerender": "node scripts/prerender.mjs",
    "bake": "node scripts/bake-card-images.mjs",
    "sync": "node scripts/sync-images.mjs",
    "viator": "node scripts/sync-viator.mjs"
  },
  "dependencies": {
    "@libsql/client": "^0.17.4",
    "dompurify": "^3.4.12",
    "drizzle-orm": "^0.45.2",
    "fflate": "^0.8.3",
    "google-auth-library": "^9.15.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.460.0",
    "lz-string": "^1.5.0",
    "mapbox-gl": "^3.8.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.3",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "vite": "^5.4.11",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10"
  }
}
