{
  "name": "italy-travel-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n web,api -c cyan,green \"vite\" \"node dev-server.mjs\"",
    "build": "vite build",
    "preview": "vite preview",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node db/migrate.mjs",
    "db:seed": "node db/seed.mjs",
    "db:studio": "drizzle-kit studio",
    "db:reset": "rm -f local.db && npm run db:migrate && npm run db:seed",
    "dev:web": "vite",
    "dev:api": "node dev-server.mjs",
    "lint:hooks": "eslint --config eslint.hooks.config.mjs src --no-warn-ignored"
  },
  "dependencies": {
    "@libsql/client": "^0.17.4",
    "drizzle-orm": "^0.45.2",
    "google-auth-library": "^9.15.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.460.0",
    "lz-string": "^1.5.0",
    "mapbox-gl": "^3.8.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.3",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "vite": "^5.4.11",
    "vite-plugin-pwa": "^1.3.0"
  }
}